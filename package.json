{
    "name":  "edu-video-gen",
    "private":  true,
    "packageManager":  "pnpm@10.0.0",
    "scripts":  {
                    "dev:web":  "pnpm --filter web dev",
                    "dev:api":  "pnpm --filter api start:dev",
                    "test":  "vitest run",
                    "typecheck":  "tsc -p tsconfig.base.json --noEmit",
                    "vercel-build":  "pnpm --filter web build",
                    "build:web":  "pnpm --filter web build",
                    "build":  "pnpm build:web \u0026\u0026 node -e \"const fs=require(\u0027fs\u0027); fs.rmSync(\u0027.next\u0027,{recursive:true,force:true}); fs.cpSync(\u0027apps/web/.next\u0027,\u0027.next\u0027,{recursive:true});\"",
                    "verify:v1":  "pnpm test \u0026\u0026 pnpm typecheck"
                },
    "dependencies":  {
                         "@nestjs/common":  "^11.1.6",
                         "@nestjs/core":  "^11.1.6",
                         "@nestjs/platform-express":  "^11.1.6",
                         "@remotion/bundler":  "^4.0.451",
                         "@remotion/renderer":  "^4.0.451",
                         "next":  "^15.5.6",
                         "react":  "^19.1.1",
                         "react-dom":  "^19.1.1",
                         "reflect-metadata":  "^0.2.2",
                         "remotion":  "^4.0.451",
                         "rxjs":  "^7.8.2",
                         "supertest":  "^7.1.4",
                         "zod":  "^3.24.1"
                     },
    "devDependencies":  {
                            "@types/node":  "^24.0.0",
                            "@types/react":  "19.2.14",
                            "@types/react-dom":  "^19.2.3",
                            "tsx":  "^4.20.6",
                            "typescript":  "^5.8.0",
                            "vitest":  "^3.2.0"
                        }
}
