    "next": "^15.5.6",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "reflect-metadata": "^0.2.2",
    "remotion": "^4.0.451",
    "rxjs": "^7.8.2",
    "supertest": "^7.1.4",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "^19.2.3",
    "tsx": "^4.20.6",
